NODE_ENV=development
PORT=3000
APP_VERSION=0.0.1
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,https://appleid.apple.com
DB_HOST=
DB_PORT=5432
DB_USERNAME=
DB_PASSWORD=
DB_NAME=
DB_SYNCHRONIZE=false

CACHE_TTL=300
CACHE_MAX=500
# Optional Redis URL for shared search/settings cache across Railway instances.
# When unset, Nest uses in-memory cache (per-instance only).
REDIS_URL=

# Social login toggles (default: enabled when unset; set to false to disable)
ENABLE_GOOGLE_LOGIN=true
ENABLE_FACEBOOK_LOGIN=true
ENABLE_APPLE_LOGIN=true

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=http://localhost:3001/api/auth/facebook/callback

APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_CALLBACK_URL=http://localhost:3001/api/auth/apple/callback
APPLE_PRIVATE_KEY=
# APPLE_PRIVATE_KEY_LOCATION=

OPENAI_API_KEY=
OPENAI_MODEL=
PRODUCT_IMPORT_OPENAI_MODEL=
PRODUCT_IMPORT_OPENAI_LOG_PATH=
GEMINI_API_KEY=

# Cloudflare R2 (media uploads)
R2_BUCKET_NAME=
R2_ACCOUNT_ID=
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Public base URL only — no trailing slash. Do not append /products; object keys already include products/...
R2_PUBLIC_URL=

# Search provider: db | typesense
SEARCH_PROVIDER=typesense
SEARCH_EXPANSION_ENABLED=true
SEARCH_EXPANSION_MAX_CANDIDATES=240
SEARCH_EXPANSION_MIN_TEXT_MATCH_RATIO=0.4
# Skip progressive expansion when primary Typesense hits reach this count (env-tunable)
SEARCH_EXPANSION_PRIMARY_ENOUGH_COUNT=125
SEARCH_EXPANSION_EXTRA_WHEN_LOW=100
# Cache full ordered expansion IDs (page-independent) for brand bucket queries (default 5 min)
SEARCH_EXPANSION_ORDERED_IDS_CACHE_TTL_MS=300000
# Max concept synonym combinations per expansion step (prevents query explosion)
SEARCH_EXPANSION_MAX_CONCEPT_VARIANT_COMBOS=50
# Cap synonyms per concept segment in expansion queries. When
# SEARCH_TYPESENSE_CONCEPT_SYNONYMS=true, default is 1 (user term only —
# Typesense expands the rest). Set 0 for unlimited. Without Typesense synonyms,
# default is 0 (full lexicon variants).
SEARCH_EXPANSION_MAX_VARIANTS_PER_CONCEPT=1
# Comma-separated expansion levels: strong_partial,category_brand,category,brand,specification,keyword
SEARCH_EXPANSION_LEVELS=strong_partial,same_brand_spec,cross_brand_spec,category_brand,category,brand,specification,keyword
# Sync term_groups to Typesense synonyms; with this on, expansion defaults to
# one variant per concept (see SEARCH_EXPANSION_MAX_VARIANTS_PER_CONCEPT).
SEARCH_TYPESENSE_CONCEPT_SYNONYMS=true
# Parallel Typesense queries during concept-tier expansion (default 8)
SEARCH_EXPANSION_CONCEPT_QUERY_CONCURRENCY=8
# Batch concept synonym queries into one Typesense multi_search request (default 48).
# Typesense default limit_multi_searches is 50 — keep batch ≤ 48 so primary/keyword fit.
SEARCH_EXPANSION_CONCEPT_MULTI_SEARCH_BATCH=48
SEARCH_LATENCY_BUDGET_MS=350
# When true: startup logs confirm debug is on; each search prints a full report
# in application logs (filter by "[search-debug]"). Use: true  (no quotes)
SEARCH_DEBUG_ENABLED=false

# Typesense — Railway production (typesense-railway service)
TYPESENSE_ENABLED=true
# Public domain — use when backend runs locally (same API key as internal block)
# Copy from Railway → typesense-railway → Settings → Networking → Public Domain
TYPESENSE_HOST=typesense-railway-production-683b.up.railway.app
TYPESENSE_PORT=443
TYPESENSE_PROTOCOL=https
TYPESENSE_API_KEY=
TYPESENSE_COLLECTION_PRODUCTS=products
TYPESENSE_TIMEOUT_SECONDS=10

# Railway private networking — use when ordonsooq-be runs on Railway
# TYPESENSE_HOST=typesense-railway.railway.internal
# TYPESENSE_PORT=8080
# TYPESENSE_PROTOCOL=http
# TYPESENSE_API_KEY=<same key as typesense-railway service on Railway>

# Local Docker Typesense (see README — docker run typesense/typesense:30.2)
# TYPESENSE_ENABLED=true
# TYPESENSE_HOST=localhost
# TYPESENSE_PORT=8108
# TYPESENSE_PROTOCOL=http
# TYPESENSE_API_KEY=your_local_dev_key_123
# TYPESENSE_COLLECTION_PRODUCTS=products
# TYPESENSE_TIMEOUT_SECONDS=10

# Google Analytics 4 (Data API — admin dashboard)
GA4_PROPERTY_ID=
# Path to service account JSON (local), or paste full JSON into GA4_CREDENTIALS_JSON (cloud)
GA4_CREDENTIALS_PATH=./secrets/ga4-service-account.json
# GA4_CREDENTIALS_JSON=
